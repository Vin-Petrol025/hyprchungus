{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
	"cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 960, 
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,

  "notification-window-width": 600,
  "notification-icon-size": 60,
  "notification-body-image-height": 0,
  "notification-body-image-width": 0,

  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 6,
  
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 100,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "mpris",
    "buttons-grid",
    "volume",
    "backlight",
    "dnd",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "",
      "clear-all-button": true,
      "button-text": "Clear All "
    },
    "dnd": {
      "text": "Do not disturb",
      "do-not-disturb-on-startup": false,
     "do-not-disturb": false

    },
    "label": {
      "max-lines": 1,
      "text": " "
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 19,
      "show-album-art": "playing",
      "blacklist": [
        "firefox",
        "chromium",
        "brave",
        "mpv",
        "playerctl"
      ],
      "autohide": true,
      "prefer": ["spotify"]
      
    },
    "volume": {
      "label": "¾░ĢŠ ",
        "show-per-app": false
    },
    "backlight": {
      "label": "¾░āĀ ",
      "device": "amdgpu_bl1",
      "subsystem": "backlight", 
      "min": 10
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "’Ćź",
          "command": "amixer set Master toggle",
          "name": "btn-audio"
        },
        {
          "label": "’ä░",
          "command": "amixer set Capture toggle"
        },
        {
          "label": "’ć½ ",
          "command": "swaync-client -t -sw; ~/.config/rofi/launchers/wifi.sh" 
        },
        {
          "label": "¾░é»",
          "command": "swaync-client -t -sw; ~/.config/rofi/launchers/rofi-bluetooth"
        },
        {
          "label": "¾░Åś",
          "command": "hyprpicker"
        },

        {
          "label": "¾░ŗ®",
          "command": "swaync-client -t -sw; ~/.config/rofi/launchers/wall-changer.sh"
        },
        {     
          "label": "’éā ",
          "command": "flameshot gui"
        },
        {
          "label": "’Ćæ",
          "command": "swaync-client -t -sw; ~/.config/rofi/launchers/powermenu.sh"
        }

      ]
    }
  }
}
